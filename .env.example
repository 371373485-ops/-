# Backend
APP_ENV=development
USE_MOCK_AI=true

# AI Provider. Current implemented providers: mock, openai, openai_compatible.
# Keep API keys empty in source control.
AI_PROVIDER=openai
# AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=30
AI_MAX_TOKENS=4096

# OpenAI-compatible examples. Uncomment and fill AI_API_KEY locally only.
# DeepSeek:
# AI_PROVIDER=openai_compatible
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
#
# Qwen compatible mode:
# AI_PROVIDER=openai_compatible
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus
#
# Kimi:
# AI_PROVIDER=openai_compatible
# AI_BASE_URL=https://api.moonshot.cn/v1
# AI_MODEL=moonshot-v1-8k

# Backward-compatible OpenAI variables.
# Set USE_MOCK_AI=false and provide OPENAI_API_KEY locally to enable real AI mode.
# If the API call fails, the backend falls back to local rule diagnosis.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30

# SQLite sample library. Optional.
# SAMPLE_DB_PATH=backend/data/samples.sqlite3

# CORS. Use comma-separated origins in online demo deployments.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# FRONTEND_ORIGINS=https://your-temporary-frontend.trycloudflare.com
# CORS_ORIGIN_REGEX=

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
